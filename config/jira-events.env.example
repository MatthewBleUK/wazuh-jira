# Jira audit integration
#
# The integration polls the Jira audit API through the Atlassian API gateway.
# Replace <cloud-id> with your site's cloud id, shown at:
#   https://<your-site>.atlassian.net/_edge/tenant_info
# Values are read literally by the poller; ${VAR} substitution is NOT
# supported, so the cloud id must be written inline.
#
# When JIRA_AUDIT_PATH is a full https:// URL it is used as the complete
# request URL and JIRA_BASE_URL is not part of the request. Still keep
# JIRA_BASE_URL set to your real site URL (no trailing slash): its hostname
# labels every event's jira_site_host field.
JIRA_BASE_URL=https://your-site.atlassian.net
JIRA_AUDIT_PATH=https://api.atlassian.com/ex/jira/<cloud-id>/rest/api/3/auditing/record

# Alternative endpoints (relative paths are appended to JIRA_BASE_URL):
#   Direct site URL, no gateway:  JIRA_AUDIT_PATH=/rest/api/3/auditing/record
#   Older Jira/Data Center:       JIRA_AUDIT_PATH=/rest/auditing/1.0/events

# Authentication mode:
#   basic  - Jira Cloud email/API token or a Jira user/password pair
#   bearer - Jira Data Center personal access token or reverse-proxy bearer token
#   auto   - bearer if JIRA_BEARER_TOKEN/JIRA_PAT is set, otherwise basic if username+token are set
JIRA_AUTH_MODE=auto

# Basic auth settings. For Jira Cloud, use the user's email address and API token.
JIRA_USERNAME=<jira admin username or email>
JIRA_API_TOKEN=<jira api token or password>
# JIRA_API_TOKEN_FILE=/var/ossec/etc/jira-api-token.secret

# Bearer/PAT auth settings. Use one of these for Jira Data Center PAT auth.
# JIRA_BEARER_TOKEN=<jira bearer token>
# JIRA_PAT=<jira personal access token>
# JIRA_BEARER_TOKEN_FILE=/var/ossec/etc/jira-bearer-token.secret

# First-run backfill window. Later runs query from the saved high-water mark
# with a dedupe lookback so late-arriving records are not missed.
JIRA_BACKFILL_HOURS=24
JIRA_LOOKBACK_SECONDS=300
JIRA_SEEN_RETENTION_HOURS=48

# Pagination and HTTP behavior.
JIRA_LIMIT=1000
JIRA_MAX_PAGES=10
JIRA_HTTP_TIMEOUT=60
JIRA_SLEEP_BETWEEN_PAGES=0.5

# Query timestamp format:
#   jira     2026-07-04T10:00:00.000+0000
#   iso      2026-07-04T10:00:00.000Z
#   epoch_ms 1783159200000
JIRA_TIME_FORMAT=jira
JIRA_INCLUDE_TO=true

# Optional extra URL query string, for example: filter=permission&sortOrder=asc
# JIRA_EXTRA_QUERY=

JIRA_DEBUG=false
